</span></span><span class="line"><span class="cl"><span class="gp">$</span> docker buildx build -o outdir .
</span></span><span class="line"><span class="cl"><span class="gp">$</span> docker buildx build -o - . &gt; out.tar
</span></span><span class="line"><span class="cl"><span class="gp">$</span> docker buildx build -o <span class="nv">type</span><span class="o">=</span>docker .
